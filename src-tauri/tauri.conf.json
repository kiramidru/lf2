{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "lf2",
    "version": "0.1.0",
    "identifier": "com.kira.lf2",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "lf2",
                "width": 800,
                "height": 600,
                "url": "F.LF/game/game.html"
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": false,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
